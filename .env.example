# =============================================================================
# TORUN COACH — Environment Variables
# Kopiera denna fil till .env.local och fyll i värdena.
# .env.local läses automatiskt av Next.js i utveckling.
# I produktion (Vercel): lägg in samma variabler under Project → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# RESEND — för transaktionsmejl (subscribe + kontaktformulär + Stripe-bekräftelser)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_PLACEHOLDER_REPLACE_ME
# Format: "Namn <mejl@verifierad-domän.se>" — domänen måste vara verifierad hos Resend
RESEND_FROM=TORUN. <onboarding@resend.dev>
NOTIFY_EMAIL=itorun@me.com

# URL till startguide-PDF som skickas vid newsletter-anmälan
GUIDE_URL=https://torun.se/torun-startguide.pdf
# URL till Kickstart-PDF som skickas efter betalning
KICKSTART_PDF_URL=https://torun.se/kickstart-startguide.pdf

# -----------------------------------------------------------------------------
# STRIPE — för betalningar
# Hämta från https://dashboard.stripe.com/test/apikeys (test mode) eller
# https://dashboard.stripe.com/apikeys (live mode)
# -----------------------------------------------------------------------------
# Secret key — börjar med sk_test_ (test) eller sk_live_ (live)
STRIPE_SECRET_KEY=PLACEHOLDER_REPLACE_ME

# Price ID för Kickstart-produkten — börjar med price_
# Skapas i Stripe Dashboard → Products → New product
STRIPE_PRICE_KICKSTART=price_PLACEHOLDER_REPLACE_ME

# Webhook signing secret — börjar med whsec_
# Lokal utveckling: kör `stripe listen --forward-to localhost:3000/api/webhook/stripe`
# Produktion: skapas i Dashboard → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER_REPLACE_ME

# -----------------------------------------------------------------------------
# SITE — den publika URL:en till sajten (används för Stripe success/cancel)
# -----------------------------------------------------------------------------
# Lokalt:  http://localhost:3000
# Live:    https://torun.se
NEXT_PUBLIC_SITE_URL=http://localhost:3000
